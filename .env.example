# ===========================================
# React Clean Architecture - Environment Config
# ===========================================

# ----------------------
# API Configuration
# ----------------------
# REST API base URL
VITE_API_BASE_URL=http://localhost:3000/api

# ----------------------
# GraphQL Configuration
# ----------------------
# Enable GraphQL instead of REST (true/false)
VITE_USE_GRAPHQL=false

# GraphQL endpoint URL
VITE_GRAPHQL_URL=http://localhost:3000/graphql

# ----------------------
# App Configuration
# ----------------------
# Application name
VITE_APP_NAME=Clean App

# Application version
VITE_APP_VERSION=1.0.0
